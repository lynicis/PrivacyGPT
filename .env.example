# Admin Portal Basic Authentication Credentials
# Default fallback username/password are "admin" and "adminpassword".
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword

# Watchdog Cron Endpoint Secret
# Used to authorize requests to the automated crawler cron path (/api/cron/watchdog).
CRON_SECRET=your_watchdog_cron_secret_here

# Cron Worker — URL of the deployed main app (required by cron-worker.ts)
APP_URL=https://privacygpt.lynicis.dev

# Firecrawl API Key — fallback scraper for blocked privacy policies
# Optional: used when plain fetch returns 401/403/timeout
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
